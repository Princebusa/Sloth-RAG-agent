# Auth.js / NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Same Postgres URL as packages/db (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Redis (Drive sync queue for ingest-worker)
REDIS_URL="redis://localhost:6379"

# Qdrant (used by ingest-worker; optional here if only worker needs it)
# QDRANT_URL=
# QDRANT_API_KEY=
